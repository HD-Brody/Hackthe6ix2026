п»ї# ГўвЂќв‚¬ГўвЂќв‚¬ Professor Me environment ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
# Owner: D. Copy to .env.local and fill in. D confirms every key
# actually works (not free-tier-limited) at CP0.

# Gemini (concept graph, evaluator, persona, gap map)
GEMINI_API_KEY=

# Model tier split Гўв‚¬вЂќ decided at CP1 from D's latency spike. Defaults are placeholders.
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_STRONG=gemini-2.5-pro

# Vertex AI (optional). Set GOOGLE_GENAI_USE_VERTEXAI=true to bill Gemini
# calls through a GCP project (ADC auth) instead of GEMINI_API_KEY Гўв‚¬вЂќ bypasses
# free-tier RPM limits. Requires `gcloud auth application-default login` and
# `gcloud auth application-default set-quota-project <project>` locally.
# Leave unset/false to keep using GEMINI_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# ElevenLabs (student voice)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Browser-side restricted key (Text-to-Speech permission ONLY Гўв‚¬вЂќ not the same as above).
# Must be NEXT_PUBLIC_ so Next.js includes it in the browser bundle.
# Create at: ElevenLabs dashboard ГўвЂ вЂ™ Profile ГўвЂ вЂ™ API Keys ГўвЂ вЂ™ restricted key (TTS only).
NEXT_PUBLIC_ELEVENLABS_TTS_KEY=

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=professor_me

# Auth0 Гўв‚¬вЂќ AUTH0_SECRET is NOT from the dashboard: generate with `openssl rand -hex 32`
# (also set it in Vercel). Domain/client id/secret come from the Auth0 app settings.
AUTH0_SECRET=
# Host only Гўв‚¬вЂќ no https:// (e.g. your-tenant.us.auth0.com)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Local dev only. On Vercel, leave unset Гўв‚¬вЂќ the SDK infers the host from each request.
APP_BASE_URL=http://localhost:3000
# Production URL for npm run prod-sse-drill
PROD_BASE_URL=https://professor-me.vercel.app

# Feature flags
# Parallel evaluation trick (A, Block A3). DECIDED true 2026-07-18: measured
# 1202ms/turn median savings vs sequential (npm run cp2:integration, real Gemini).
PARALLEL_EVAL=true
# Browser TTS fallback if ElevenLabs credits run dry (D, Block D4)
BROWSER_TTS_FALLBACK=false
# Echo mode: turn endpoint streams canned persona lines instead of calling Gemini
ECHO_MODE=true
# Frontend-only CP1 fallback. Skips session API and stores demo sessions locally.
NEXT_PUBLIC_MOCK_MODE=false
# Mock B's LLM modules (alternate vague/solid verdicts, fixture persona + gap map)
LLM_MOCK=false
# Simulated Gemini latency when LLM_MOCK=true (ms)
MOCK_EVAL_MS=800
MOCK_PERSONA_FIRST_TOKEN_MS=600
MOCK_TOKEN_MS=40
# Max user turns per session before 400 turn_cap_reached (A4)
MAX_TURNS_PER_SESSION=40
# Max sessions per user_id before 429 session_cap_reached (A4)
MAX_SESSIONS_PER_USER=10

# Unifold tips (optional "Support the developers")
# Publishable key is safe for the browser. Secret key stays server-only.
NEXT_PUBLIC_UNIFOLD_PUBLISHABLE_KEY=
UNIFOLD_SECRET_KEY=
# Webhook signing secret from Unifold Dashboard -> Webhooks
UNIFOLD_WEBHOOK_SECRET=
# Your Base wallet that receives tip USDC (required for live checkout).
UNIFOLD_RECIPIENT_ADDRESS=
UNIFOLD_DESTINATION_NETWORK=base
# When true, /support records a tip without crypto (hackathon demos).
BILLING_MOCK=true
